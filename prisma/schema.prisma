generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  hashedPassword String?
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  accounts  Account[]
  sessions  Session[]
  preferences UserPreference?
  watchlists  Watchlist[]
  savedArticles  SavedArticle[]
  savedEpisodes SavedEpisode[]
  briefingSnapshots BriefingSnapshot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  timezone          String   @default("America/New_York")
  briefingSchedule  String   @default("morning")
  marketInterests   String[]
  podcastInterests  String[]
  theme             String   @default("dark")
  countryFocus      String   @default("us")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Watchlist")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]
}

model WatchlistItem {
  id           String   @id @default(cuid())
  watchlistId  String
  symbol       String
  companyName  String?
  exchangeCode String?
  sortOrder    Int      @default(0)
  addedAt      DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
}

model SavedArticle {
  id                String   @id @default(cuid())
  userId            String
  articleProviderId String
  title             String
  url               String
  savedAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleProviderId])
}

model SavedEpisode {
  id                 String   @id @default(cuid())
  userId             String
  episodeProviderId  String
  podcastTitle       String
  episodeTitle       String
  audioUrl           String?
  savedAt            DateTime @default(now())
  progressSeconds    Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeProviderId])
}

model BriefingSnapshot {
  id          String   @id @default(cuid())
  userId      String
  generatedAt DateTime @default(now())
  data        Json
  isStale     Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProviderCache {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}
